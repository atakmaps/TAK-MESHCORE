<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF1B1B1B"
    android:padding="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <TextView
            android:id="@+id/header_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="UV-PRO"
            android:textColor="#FFFFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:paddingBottom="2dp" />

        <TextView
            android:id="@+id/header_version"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="v1.8.0"
            android:textColor="#FF888888"
            android:textSize="11sp"
            android:paddingBottom="8dp" />

        <!-- ==================== CONNECTION ==================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FF2D2D2D"
            android:padding="12dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="CONNECTION"
                android:textColor="#FF00BCD4"
                android:textSize="12sp"
                android:textStyle="bold"
                android:paddingBottom="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <View
                    android:id="@+id/status_dot"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:background="#FFFF0000"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/status_text"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Disconnected"
                    android:textColor="#FFFFFFFF"
                    android:textSize="14sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/device_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#FFAAAAAA"
                android:textSize="12sp"
                android:paddingTop="2dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/favorites_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="FAVORITE RADIOS"
                android:textColor="#FF00BCD4"
                android:textSize="11sp"
                android:textStyle="bold"
                android:paddingTop="6dp"
                android:visibility="gone" />

            <HorizontalScrollView
                android:id="@+id/favorites_scroll"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="4dp"
                android:scrollbars="none"
                android:visibility="gone">

                <LinearLayout
                    android:id="@+id/favorites_strip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" />
            </HorizontalScrollView>

            <TextView
                android:id="@+id/connect_mode_hint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#FF888888"
                android:textSize="10sp"
                android:paddingTop="4dp"
                android:visibility="gone" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="8dp">

                <Button
                    android:id="@+id/btn_scan"
                    style="@style/UvproPillButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="SCAN &amp; CONNECT"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="4dp"
                    android:backgroundTint="#FF00BCD4" />

                <Button
                    android:id="@+id/btn_disconnect"
                    style="@style/UvproPillButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="DISCONNECT"
                    android:textSize="12sp"
                    android:enabled="false"
                    android:backgroundTint="#FFF44336" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Callsign:"
                    android:textColor="#FFAAAAAA"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/text_callsign"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="OPENRL"
                    android:textColor="#FFFFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="2dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Team:"
                    android:textColor="#FFAAAAAA"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/text_team_color"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Cyan"
                    android:textColor="#FF00BCD4"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="2dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Contacts:"
                    android:textColor="#FFAAAAAA"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/text_contacts"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="0 active"
                    android:textColor="#FFFFFFFF"
                    android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="2dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Packets TX / RX:"
                    android:textColor="#FFAAAAAA"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/text_packets"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="0 / 0"
                    android:textColor="#FFFFFFFF"
                    android:textSize="13sp" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ENCRYPTION"
                android:textColor="#FFFF9800"
                android:textSize="12sp"
                android:textStyle="bold"
                android:paddingTop="10dp"
                android:paddingBottom="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="AES-256-GCM encryption"
                    android:textColor="#FFFFFFFF"
                    android:textSize="13sp" />

                <Switch
                    android:id="@+id/switch_encryption"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="false" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/passphrase_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="8dp"
                android:visibility="gone">

                <EditText
                    android:id="@+id/edit_passphrase"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:hint="Shared secret"
                    android:textColor="#FFFFFFFF"
                    android:textColorHint="#FF666666"
                    android:textSize="13sp"
                    android:background="#FF1B1B1B"
                    android:padding="8dp"
                    android:inputType="textPassword"
                    android:singleLine="true"
                    android:layout_marginEnd="4dp" />

                <Button
                    android:id="@+id/btn_set_passphrase"
                    style="@style/UvproPillButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SET"
                    android:textSize="11sp"
                    android:backgroundTint="#FFFF9800"
                    android:minWidth="60dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/text_encryption_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="All radios must use the same shared secret"
                android:textColor="#FF888888"
                android:textSize="11sp"
                android:paddingTop="4dp" />

        </LinearLayout>

        <!-- ==================== CHANNEL CONTROL ==================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FF2D2D2D"
            android:padding="12dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="CHANNEL CONTROL"
                android:textColor="#FF00BCD4"
                android:textSize="12sp"
                android:textStyle="bold"
                android:paddingBottom="4dp" />

            <Button
                android:id="@+id/btn_radio_silence"
                style="@style/UvproPillButton.Beacon"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Long Press for Radio Silence"
                android:backgroundTint="#FF455A64" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Selected Repeater"
                android:textColor="#FFAAAAAA"
                android:textSize="11sp"
                android:paddingTop="4dp" />

            <TextView
                android:id="@+id/text_selected_repeater"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="None selected"
                android:textColor="#FFFFFFFF"
                android:textSize="12sp"
                android:paddingTop="2dp"
                android:paddingBottom="6dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingBottom="8dp">

                <Button
                    android:id="@+id/btn_load_selected_repeater"
                    style="@style/UvproPillButton.Beacon"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Load Selected Repeater"
                    android:enabled="false"
                    android:backgroundTint="#FF455A64" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="4dp">

                <Button
                    android:id="@+id/btn_tx_power"
                    style="@style/UvproPillButton.Beacon"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="TX Power LOW"
                    android:enabled="false"
                    android:backgroundTint="#FF455A64" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Enable Dual Watch"
                    android:textColor="#FFFFFFFF"
                    android:textSize="13sp"
                    android:layout_marginEnd="8dp"
                    android:gravity="end" />

                <Switch
                    android:id="@+id/switch_dual_watch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="false"
                    android:showText="false"
                    android:textColor="#FFFFFFFF"
                    android:switchMinWidth="56dp"
                    android:contentDescription="Dual watch radio switch" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="4dp"
                android:paddingBottom="2dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="RX Signal:"
                    android:textColor="#FFFFFFFF"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/text_receive_rssi"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="#FFFFFFFF"
                    android:textSize="13sp"
                    android:minWidth="48dp"
                    android:gravity="end" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/rssi_meter_block"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="6dp"
                android:visibility="gone">

                <FrameLayout
                    android:id="@+id/frame_receive_rssi"
                    android:layout_width="match_parent"
                    android:layout_height="18dp">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/rssi_meter_track" />

                    <View
                        android:id="@+id/view_receive_rssi_fill_green"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:background="#FF4CAF50" />

                    <View
                        android:id="@+id/view_receive_rssi_fill_red"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:background="#FFF44336"
                        android:visibility="gone" />
                </FrameLayout>

                <FrameLayout
                    android:id="@+id/frame_receive_rssi_scale"
                    android:layout_width="match_parent"
                    android:layout_height="24dp"
                    android:layout_marginTop="3dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Long press for TX"
                    android:textColor="#FFFFFFFF"
                    android:textSize="13sp"
                    android:gravity="start|center_vertical" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <Switch
                        android:id="@+id/switch_digital_edit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="false"
                        android:showText="false"
                        android:textColor="#FFFFFFFF"
                        android:switchMinWidth="56dp"
                        android:contentDescription="Enable digital channel editing" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="Enable Digital Edit"
                        android:textColor="#FFFFFFFF"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingBottom="8dp">

                <Button
                    android:id="@+id/btn_vfo_a"
                    style="@style/UvproPillButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="A: CH--"
                    android:textSize="15sp"
                    android:gravity="start|center_vertical"
                    android:paddingStart="10dp"
                    android:layout_marginEnd="4dp"
                    android:backgroundTint="#FF00695C" />

                <Button
                    android:id="@+id/btn_vfo_b"
                    style="@style/UvproPillButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="B: CH--"
                    android:textSize="15sp"
                    android:gravity="start|center_vertical"
                    android:paddingStart="10dp"
                    android:layout_marginEnd="4dp"
                    android:backgroundTint="#FF2E7D32"
                    android:visibility="gone" />

                <Button
                    android:id="@+id/btn_digital"
                    style="@style/UvproPillButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Digital"
                    android:textSize="15sp"
                    android:backgroundTint="#FF005A8D" />
            </LinearLayout>

            <GridLayout
                android:id="@+id/grid_channels"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="5"
                android:useDefaultMargins="true" />

            <Button
                android:id="@+id/btn_digital_only_mode"
                style="@style/UvproPillButton.Beacon"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="DIGITAL ONLY MODE"
                android:enabled="false"
                android:backgroundTint="#FF455A64" />
        </LinearLayout>

        <!-- ==================== BEACON (interval display) ==================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FF2D2D2D"
            android:padding="12dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="BEACON"
                android:textColor="#FF00BCD4"
                android:textSize="12sp"
                android:textStyle="bold"
                android:paddingBottom="4dp" />

            <Button
                android:id="@+id/btn_send_beacon"
                style="@style/UvproPillButton.Beacon"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="Send Beacon"
                android:backgroundTint="#FF455A64" />

            <Button
                android:id="@+id/btn_send_ping"
                style="@style/UvproPillButton.Beacon"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Send Ping"
                android:backgroundTint="#FF455A64" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Smart Beacon"
                    android:textColor="#FFFFFFFF"
                    android:textSize="13sp" />

                <Switch
                    android:id="@+id/switch_smart_beacon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Adapts beacon rate to speed and heading changes."
                android:textColor="#FF888888"
                android:textSize="11sp"
                android:paddingTop="2dp"
                android:paddingBottom="4dp" />

            <Button
                android:id="@+id/btn_manage_smart_beacon_settings"
                style="@style/UvproPillButton.Beacon"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Smart Beacon Settings"
                android:backgroundTint="#FF455A64" />

            <LinearLayout
                android:id="@+id/row_beacon_interval"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="8dp">

                <TextView
                    android:id="@+id/text_gps_beacon_interval_label"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="GPS Beacon Interval"
                    android:textColor="#FFFFFFFF"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/text_beacon_interval"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="60s"
                    android:textColor="#FF00BCD4"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <Button
                android:id="@+id/btn_manage_plugin_beacon_settings"
                style="@style/UvproPillButton.Beacon"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Beacon Settings"
                android:backgroundTint="#FF455A64" />
        </LinearLayout>

        <!-- ==================== APRS ==================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FF2D2D2D"
            android:padding="12dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="APRS"
                android:textColor="#FF00BCD4"
                android:textSize="12sp"
                android:textStyle="bold"
                android:paddingBottom="4dp" />

            <Button
                android:id="@+id/btn_aprs_beacon_arm"
                style="@style/UvproPillButton.Beacon"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="Long Press for APRS Beacon"
                android:backgroundTint="#FF455A64" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="APRS Beaconing will follow ATAK Beacon Settings"
                android:textColor="#FFB0BEC5"
                android:textSize="11sp"
                android:paddingBottom="4dp" />

            <TextView
                android:id="@+id/text_aprs_status_call"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Call: (not set)"
                android:textColor="#FFCCCCCC"
                android:textSize="12sp"
                android:paddingTop="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="4dp"
                android:paddingBottom="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Icon:"
                    android:textColor="#FFCCCCCC"
                    android:textSize="12sp"
                    android:paddingEnd="8dp" />

                <ImageView
                    android:id="@+id/image_aprs_status_icon"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:scaleType="fitCenter"
                    android:contentDescription="APRS icon preview"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/text_aprs_status_icon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="(not set)"
                    android:textColor="#FF888888"
                    android:textSize="12sp"
                    android:paddingStart="4dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/text_aprs_status_message"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="APRS Message: No Message"
                android:textColor="#FFCCCCCC"
                android:textSize="12sp"
                android:paddingTop="2dp"
                android:paddingBottom="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="4dp"
                android:paddingBottom="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Disable ATAK traffic"
                    android:textColor="#FFFFFFFF"
                    android:textSize="13sp" />

                <Switch
                    android:id="@+id/switch_aprs_disable_atak"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="When off, ATAK (UV-PRO) beacons share the GPS beacon timer; ATAK traffic wins if both are due."
                android:textColor="#FF888888"
                android:textSize="11sp"
                android:paddingBottom="6dp" />

            <Button
                android:id="@+id/btn_send_aprs_beacon"
                style="@style/UvproPillButton.Beacon"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text="Send APRS Beacon"
                android:backgroundTint="#FF455A64" />

            <Button
                android:id="@+id/btn_edit_aprs_settings"
                style="@style/UvproPillButton.Beacon"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Edit APRS Settings"
                android:backgroundTint="#FF455A64" />
        </LinearLayout>

        <!-- ==================== ACTIONS ==================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FF2D2D2D"
            android:padding="12dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ACTIONS"
                android:textColor="#FF00BCD4"
                android:textSize="12sp"
                android:textStyle="bold"
                android:paddingBottom="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Plugin settings: tap the button below. Full ATAK list: Settings → Tool Preferences → UV-PRO Settings."
                android:textColor="#FF888888"
                android:textSize="11sp"
                android:paddingBottom="6dp" />

            <Button
                android:id="@+id/btn_settings"
                style="@style/UvproPillButton.Beacon"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Plugin Settings"
                android:backgroundTint="#FF455A64" />
        </LinearLayout>

        <!-- ==================== LOG ==================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FF2D2D2D"
            android:padding="12dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="LOG"
                android:textColor="#FF00BCD4"
                android:textSize="12sp"
                android:textStyle="bold"
                android:paddingBottom="4dp" />

            <TextView
                android:id="@+id/text_log"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:text=""
                android:textColor="#FF888888"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:scrollbars="vertical"
                android:gravity="bottom"
                android:background="#FF1B1B1B"
                android:padding="4dp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
