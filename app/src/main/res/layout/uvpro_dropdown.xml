<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF1B1B1B"
    android:padding="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/header_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="MeshCore"
            android:textColor="#FFFFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:paddingBottom="2dp" />

        <TextView
            android:id="@+id/header_version"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="v1.2"
            android:textColor="#FF888888"
            android:textSize="11sp"
            android:paddingBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FF2D2D2D"
            android:padding="12dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="CONNECTION"
                android:textColor="#FF00BCD4"
                android:textSize="12sp"
                android:textStyle="bold"
                android:paddingBottom="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <View
                    android:id="@+id/status_dot"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:background="#FFFF0000"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/status_text"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Disconnected"
                    android:textColor="#FFFFFFFF"
                    android:textSize="14sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/device_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#FFAAAAAA"
                android:textSize="12sp"
                android:paddingTop="2dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/favorites_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="FAVORITE MESH"
                android:textColor="#FF00BCD4"
                android:textSize="11sp"
                android:textStyle="bold"
                android:paddingTop="6dp"
                android:visibility="gone" />

            <HorizontalScrollView
                android:id="@+id/favorites_scroll"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="4dp"
                android:scrollbars="none"
                android:visibility="gone">

                <LinearLayout
                    android:id="@+id/favorites_strip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" />
            </HorizontalScrollView>

            <TextView
                android:id="@+id/connect_mode_hint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#FF888888"
                android:textSize="10sp"
                android:paddingTop="4dp"
                android:visibility="gone" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="8dp">

                <Button
                    android:id="@+id/btn_scan"
                    style="@style/UvproPillButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="SCAN &amp; CONNECT"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="4dp"
                    android:backgroundTint="#FF00BCD4" />

                <Button
                    android:id="@+id/btn_disconnect"
                    style="@style/UvproPillButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="DISCONNECT"
                    android:textSize="12sp"
                    android:enabled="false"
                    android:backgroundTint="#FFF44336" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Callsign:"
                    android:textColor="#FFAAAAAA"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/text_callsign"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="UNKNOWN"
                    android:textColor="#FFFFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="2dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Contacts:"
                    android:textColor="#FFAAAAAA"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/text_contacts"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="0 active / 0 total"
                    android:textColor="#FFFFFFFF"
                    android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="2dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Packets TX / RX:"
                    android:textColor="#FFAAAAAA"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/text_packets"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="0 / 0"
                    android:textColor="#FFFFFFFF"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FF2D2D2D"
            android:padding="12dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ACTIONS"
                android:textColor="#FF00BCD4"
                android:textSize="12sp"
                android:textStyle="bold"
                android:paddingBottom="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Manage saved Bluetooth devices and favorites."
                android:textColor="#FF888888"
                android:textSize="11sp"
                android:paddingBottom="6dp" />

            <Button
                android:id="@+id/btn_send_beacon"
                style="@style/UvproPillButton.Beacon"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Send Beacon"
                android:backgroundTint="#FF455A64" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Enable MeshCore GPS"
                    android:textColor="#FFAAAAAA"
                    android:textSize="13sp" />

                <Switch
                    android:id="@+id/switch_mesh_enable_gps"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <Button
                android:id="@+id/btn_update_gps_from_meshcore"
                style="@style/UvproPillButton.Beacon"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Update ATAK with MeshCore GPS"
                android:layout_marginTop="6dp"
                android:visibility="gone"
                android:backgroundTint="#FF455A64" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Enable Smart Beacon"
                    android:textColor="#FFAAAAAA"
                    android:textSize="13sp" />

                <Switch
                    android:id="@+id/switch_smart_beacon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <Button
                android:id="@+id/btn_smart_beacon_settings"
                style="@style/UvproPillButton.Beacon"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Smart Beacon Settings"
                android:layout_marginTop="6dp"
                android:backgroundTint="#FF455A64" />

            <Button
                android:id="@+id/btn_beacon_settings"
                style="@style/UvproPillButton.Beacon"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Beacon Settings"
                android:layout_marginTop="6dp"
                android:backgroundTint="#FF455A64" />

            <Button
                android:id="@+id/btn_plugin_settings"
                style="@style/UvproPillButton.Beacon"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Plugin Settings"
                android:layout_marginTop="6dp"
                android:backgroundTint="#FF455A64" />

            <Button
                android:id="@+id/btn_settings"
                style="@style/UvproPillButton.Beacon"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Manage Bluetooth Devices"
                android:layout_marginTop="6dp"
                android:backgroundTint="#FF455A64" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FF2D2D2D"
            android:padding="12dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="LOG"
                android:textColor="#FF00BCD4"
                android:textSize="12sp"
                android:textStyle="bold"
                android:paddingBottom="4dp" />

            <TextView
                android:id="@+id/text_log"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:text=""
                android:textColor="#FF888888"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:scrollbars="vertical"
                android:gravity="bottom"
                android:background="#FF1B1B1B"
                android:padding="4dp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
