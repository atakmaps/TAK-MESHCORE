<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="#E6000000">

    <TextView
        android:id="@+id/mesh_details_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="MESHCORE"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/mesh_details_subtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="MeshCore contact summary"
        android:textColor="#B0BEC5"
        android:textSize="12sp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="12dp"
        android:fillViewport="true">

        <TextView
            android:id="@+id/mesh_details_body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:lineSpacingExtra="4dp"
            android:textIsSelectable="true" />
    </ScrollView>

    <Button
        android:id="@+id/mesh_details_favorite"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="8dp"
        android:text="Favorite"
        android:textColor="#FFFFFF"
        android:backgroundTint="#FF455A64" />

    <Button
        android:id="@+id/mesh_details_send_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="Send Message"
        android:textColor="#FFFFFF"
        android:backgroundTint="#FF1976D2" />

    <Button
        android:id="@+id/mesh_details_delete_contact"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Delete Contact"
        android:textColor="#FFFFFF"
        android:backgroundTint="#FFD32F2F" />
</LinearLayout>
