<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="#FF1B1B1B">

    <TextView
        android:id="@+id/text_mesh_channel_expanded_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#FF00BCD4"
        android:textSize="14sp"
        android:textStyle="bold"
        android:paddingBottom="8dp" />

    <TextView
        android:id="@+id/text_mesh_channel_expanded_log"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:minHeight="240dp"
        android:background="#FF121212"
        android:padding="8dp"
        android:scrollbars="vertical"
        android:textColor="#FFF0F0F0"
        android:textSize="15sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="10dp">

        <EditText
            android:id="@+id/edit_mesh_channel_expanded_message"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:imeOptions="actionSend"
            android:inputType="textCapSentences|textMultiLine"
            android:maxLines="4"
            android:hint="Channel message"
            android:textColor="#FFFFFFFF"
            android:textColorHint="#FF888888" />

        <Button
            android:id="@+id/btn_mesh_channel_expanded_send"
            style="@style/MeshcorePillButton.Beacon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Send"
            android:background="@drawable/bg_meshcore_button_yellow" />
    </LinearLayout>

    <Button
        android:id="@+id/btn_mesh_channel_expanded_close"
        style="@style/MeshcorePillButton.Beacon"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Close"
        android:background="@drawable/bg_meshcore_button_yellow" />

</LinearLayout>
