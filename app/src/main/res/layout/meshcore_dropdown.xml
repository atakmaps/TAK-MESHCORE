<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF1B1B1B"
    android:padding="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <TextView
            android:id="@+id/header_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="MESHCORE"
            android:textColor="#FFFFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:paddingBottom="2dp" />

        <TextView
            android:id="@+id/header_version"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="v1.3.4"
            android:textColor="#FF888888"
            android:textSize="11sp"
            android:paddingBottom="8dp" />

        <!-- ==================== CONNECTION ==================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_meshcore_connection_section_red"
            android:padding="12dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="CONNECTION"
                android:textColor="#FF00BCD4"
                android:textSize="12sp"
                android:textStyle="bold"
                android:paddingBottom="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <View
                    android:id="@+id/status_dot"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:background="#FFFF0000"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/status_text"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Disconnected"
                    android:textColor="#FFFFFFFF"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/mesh_connection_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:text="MeshCore Connection"
                    android:textColor="#FFFFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/device_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#FFAAAAAA"
                android:textSize="12sp"
                android:paddingTop="2dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/favorites_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="FAVORITE MESH"
                android:textColor="#FF00BCD4"
                android:textSize="11sp"
                android:textStyle="bold"
                android:paddingTop="6dp"
                android:visibility="gone" />

            <HorizontalScrollView
                android:id="@+id/favorites_scroll"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="4dp"
                android:scrollbars="none"
                android:visibility="gone">

                <LinearLayout
                    android:id="@+id/favorites_strip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" />
            </HorizontalScrollView>

            <TextView
                android:id="@+id/connect_mode_hint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#FF888888"
                android:textSize="10sp"
                android:paddingTop="4dp"
                android:visibility="gone" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="8dp">

                <Button
                    android:id="@+id/btn_scan"
                    style="@style/MeshcorePillButton.Beacon"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="SCAN &amp; CONNECT"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/bg_meshcore_connection_button_red" />

                <Button
                    android:id="@+id/btn_disconnect"
                    style="@style/MeshcorePillButton.Beacon"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="DISCONNECT"
                    android:enabled="false"
                    android:background="@drawable/bg_meshcore_connection_button_red" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Enable MeshCore GPS"
                    android:textColor="#FFFFFFFF"
                    android:textSize="13sp" />

                <Switch
                    android:id="@+id/switch_mesh_enable_gps_connection"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/row_augment_gps_from_meshcore"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Augment GPS from MeshCore"
                    android:textColor="#FFFFFFFF"
                    android:textSize="13sp" />

                <Switch
                    android:id="@+id/switch_augment_gps_from_meshcore"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:enabled="false" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ATAK GPS will be updated every two minutes"
                android:textColor="#FF888888"
                android:textSize="11sp"
                android:paddingTop="4dp"
                android:paddingBottom="2dp" />

            <Button
                android:id="@+id/btn_update_gps_from_meshcore"
                style="@style/MeshcorePillButton.Beacon"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Update GPS from MeshCore"
                android:enabled="false"
                android:background="@drawable/bg_meshcore_connection_button_red" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Callsign:"
                    android:textColor="#FFAAAAAA"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/text_callsign"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="OPENRL"
                    android:textColor="#FFFFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="2dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Team:"
                    android:textColor="#FFAAAAAA"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/text_team_color"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Cyan"
                    android:textColor="#FF00BCD4"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="2dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Contacts:"
                    android:textColor="#FFAAAAAA"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/text_contacts"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="0 active"
                    android:textColor="#FFFFFFFF"
                    android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="2dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Packets TX / RX:"
                    android:textColor="#FFAAAAAA"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/text_packets"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="0 / 0"
                    android:textColor="#FFFFFFFF"
                    android:textSize="13sp" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ENCRYPTION"
                android:textColor="#FFFF9800"
                android:textSize="12sp"
                android:textStyle="bold"
                android:paddingTop="10dp"
                android:paddingBottom="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="AES-256-GCM encryption"
                    android:textColor="#FFFFFFFF"
                    android:textSize="13sp" />

                <Switch
                    android:id="@+id/switch_encryption"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="false" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/passphrase_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="8dp"
                android:visibility="gone">

                <EditText
                    android:id="@+id/edit_passphrase"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:hint="Shared secret"
                    android:textColor="#FFFFFFFF"
                    android:textColorHint="#FF666666"
                    android:textSize="13sp"
                    android:background="#FF1B1B1B"
                    android:padding="8dp"
                    android:inputType="textPassword"
                    android:singleLine="true"
                    android:layout_marginEnd="4dp" />

                <Button
                    android:id="@+id/btn_set_passphrase"
                    style="@style/MeshcorePillButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SET"
                    android:textSize="11sp"
                    android:background="@drawable/bg_meshcore_connection_button_red"
                    android:minWidth="60dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/text_encryption_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="All radios must use the same shared secret"
                android:textColor="#FF888888"
                android:textSize="11sp"
                android:paddingTop="4dp" />

        </LinearLayout>


        <!-- ==================== BEACON (interval display) ==================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_meshcore_beacon_section_blue"
            android:padding="12dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="BEACON"
                android:textColor="#FF00BCD4"
                android:textSize="12sp"
                android:textStyle="bold"
                android:paddingBottom="4dp" />

            <Button
                android:id="@+id/btn_send_beacon"
                style="@style/MeshcorePillButton.Beacon"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="Send Beacon"
                android:background="@drawable/bg_meshcore_beacon_button_blue" />

            <Button
                android:id="@+id/btn_send_ping"
                style="@style/MeshcorePillButton.Beacon"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Send Ping"
                android:background="@drawable/bg_meshcore_beacon_button_blue" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Smart Beacon"
                    android:textColor="#FFFFFFFF"
                    android:textSize="13sp" />

                <Switch
                    android:id="@+id/switch_smart_beacon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Adapts beacon rate to speed and heading changes."
                android:textColor="#FF888888"
                android:textSize="11sp"
                android:paddingTop="2dp"
                android:paddingBottom="4dp" />

            <Button
                android:id="@+id/btn_manage_smart_beacon_settings"
                style="@style/MeshcorePillButton.Beacon"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Smart Beacon Settings"
                android:background="@drawable/bg_meshcore_beacon_button_blue" />

            <LinearLayout
                android:id="@+id/row_beacon_interval"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="8dp">

                <TextView
                    android:id="@+id/text_gps_beacon_interval_label"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="GPS Beacon Interval"
                    android:textColor="#FFFFFFFF"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/text_beacon_interval"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="300s"
                    android:textColor="#FF00BCD4"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <Button
                android:id="@+id/btn_manage_plugin_beacon_settings"
                style="@style/MeshcorePillButton.Beacon"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Beacon Settings"
                android:background="@drawable/bg_meshcore_beacon_button_blue" />
        </LinearLayout>

        <!-- ==================== MESHCORE ==================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_meshcore_section_yellow"
            android:padding="12dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="MESHCORE"
                android:textColor="#FF00BCD4"
                android:textSize="12sp"
                android:textStyle="bold"
                android:paddingBottom="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Show Repeaters"
                    android:textColor="#FFFFFFFF"
                    android:textSize="13sp" />

                <Switch
                    android:id="@+id/switch_mesh_show_repeaters"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="6dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Show Nodes"
                    android:textColor="#FFFFFFFF"
                    android:textSize="13sp" />

                <Switch
                    android:id="@+id/switch_mesh_show_nodes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp"
                android:paddingBottom="6dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Send Position With Advert"
                    android:textColor="#FFFFFFFF"
                    android:textSize="13sp" />

                <Switch
                    android:id="@+id/switch_mesh_send_position_with_advert"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp">

                <TextView
                    android:id="@+id/text_mesh_use_callsign_location"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Use UNKNOWN Location for Position"
                    android:textColor="#FFFFFFFF"
                    android:textSize="13sp" />

                <Switch
                    android:id="@+id/switch_mesh_use_callsign_location"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="6dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Enable MeshCore GPS"
                    android:textColor="#FFFFFFFF"
                    android:textSize="13sp" />

                <Switch
                    android:id="@+id/switch_mesh_enable_gps_hardware"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:enabled="false" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="6dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Use MeshCore GPS for Position"
                    android:textColor="#FFFFFFFF"
                    android:textSize="13sp" />

                <Switch
                    android:id="@+id/switch_mesh_enable_gps"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:enabled="false" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="6dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Use Custom Node Position"
                    android:textColor="#FFFFFFFF"
                    android:textSize="13sp" />

                <Switch
                    android:id="@+id/switch_mesh_use_custom_node_position"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <Button
                android:id="@+id/btn_meshcore_set_node_position_map"
                style="@style/MeshcorePillButton.Beacon"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Set Node Position on Map"
                android:background="@drawable/bg_meshcore_button_yellow" />

            <Button
                android:id="@+id/btn_meshcore_send_advert"
                style="@style/MeshcorePillButton.Beacon"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Send Advert"
                android:background="@drawable/bg_meshcore_button_yellow" />

            <Button
                android:id="@+id/btn_clear_mesh_contacts"
                style="@style/MeshcorePillButton.Beacon"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Clear All Mesh Contacts"
                android:background="@drawable/bg_meshcore_button_yellow" />

            <!-- Add Channel button — tap to subscribe to a new channel -->
            <Button
                android:id="@+id/btn_add_mesh_channel"
                style="@style/MeshcorePillButton.Beacon"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="+ Add Channel"
                android:background="@drawable/bg_meshcore_button_yellow" />

            <!-- Channel buttons strip — one button per subscribed channel -->
            <LinearLayout
                android:id="@+id/strip_mesh_channels"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="2dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/text_mesh_channel_log"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:layout_marginTop="8dp"
                android:background="#FF1A1A1A"
                android:padding="6dp"
                android:scrollbars="vertical"
                android:textColor="#FFF0F0F0"
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp">

                <EditText
                    android:id="@+id/edit_mesh_channel_index"
                    android:layout_width="44dp"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:hint="Ch"
                    android:text="0"
                    android:textColor="#FFFFFFFF"
                    android:textColorHint="#FF888888" />

                <EditText
                    android:id="@+id/edit_mesh_channel_message"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:inputType="text"
                    android:hint="Channel message"
                    android:textColor="#FFFFFFFF"
                    android:textColorHint="#FF888888" />

                <Button
                    android:id="@+id/btn_mesh_channel_send"
                    style="@style/MeshcorePillButton.Beacon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="Send"
                    android:background="@drawable/bg_meshcore_button_yellow" />
            </LinearLayout>
        </LinearLayout>

        <!-- ==================== SETTINGS ==================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FF2D2D2D"
            android:padding="12dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="SETTINGS"
                android:textColor="#FF00BCD4"
                android:textSize="12sp"
                android:textStyle="bold"
                android:paddingBottom="4dp" />

            <Button
                android:id="@+id/btn_settings"
                style="@style/MeshcorePillButton.Beacon"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:text="Plugin Settings"
                android:backgroundTint="#FF455A64" />

            <Button
                android:id="@+id/btn_mesh_node_settings"
                style="@style/MeshcorePillButton.Beacon"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:text="Node Settings"
                android:backgroundTint="#FF455A64" />

        </LinearLayout>

        <!-- ==================== LOG ==================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FF2D2D2D"
            android:padding="12dp"
