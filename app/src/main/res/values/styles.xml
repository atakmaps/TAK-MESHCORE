<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Pill-shaped buttons (rounded ends), matching the Beacon section -->
    <style name="MeshcorePillButton">
        <item name="android:background">@drawable/bg_meshcore_pill_button</item>
        <item name="android:textColor">#FFFFFFFF</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:minHeight">40dp</item>
        <item name="android:paddingLeft">16dp</item>
        <item name="android:paddingRight">16dp</item>
        <item name="android:paddingTop">8dp</item>
        <item name="android:paddingBottom">8dp</item>
        <item name="android:elevation">0dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <!-- Full-width primary actions: beacon, plugin settings, radio silence, load repeater -->
    <style name="MeshcorePillButton.Beacon">
        <item name="android:textSize">15sp</item>
    </style>
</resources>
